<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>Power Query - Development Rules</title>

  <style>
    :root {
      --pq-green: #168354;
      --pq-green-dark: #0d5f3c;
      --pq-green-soft: #eaf7f0;

      --pq-blue: #246bce;
      --pq-blue-soft: #eef5ff;

      --pq-amber: #9a6700;
      --pq-amber-soft: #fff7e6;

      --pq-red: #b42318;
      --pq-red-soft: #fff1f0;

      --text: #172b4d;
      --muted: #5e6c84;

      --border: #dfe1e6;

      --surface: #ffffff;
      --surface-soft: #f7f8fa;

      --code-background: #17212b;

      --shadow: 0 8px 24px rgba(9, 30, 66, 0.1);

      --radius-large: 18px;
      --radius-medium: 12px;
      --radius-small: 8px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;

      background: #f4f5f7;
      color: var(--text);

      font-family:
        Inter,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        Roboto,
        Arial,
        sans-serif;

      line-height: 1.55;
    }

    .document {
      max-width: 1180px;

      margin: 32px auto;

      padding:
        0
        22px
        48px;
    }

    /* =====================================================
       HEADER
    ===================================================== */

    .hero {
      position: relative;

      overflow: hidden;

      padding: 42px;

      color: #ffffff;

      border-radius: 22px;

      background:
        radial-gradient(
          circle at 88% 22%,
          rgba(255, 255, 255, 0.18),
          transparent 28%
        ),
        linear-gradient(
          135deg,
          var(--pq-green-dark),
          var(--pq-green)
        );

      box-shadow: var(--shadow);
    }

    .hero::after {
      content: "M";

      position: absolute;

      right: 34px;
      bottom: -34px;

      font-size: 190px;
      font-weight: 800;
      line-height: 1;

      color: rgba(255, 255, 255, 0.08);
    }

    .hero-label {
      display: inline-flex;

      align-items: center;

      gap: 8px;

      margin-bottom: 16px;

      padding:
        6px
        11px;

      border:
        1px solid
        rgba(255, 255, 255, 0.32);

      border-radius: 999px;

      background:
        rgba(255, 255, 255, 0.1);

      font-size: 12px;
      font-weight: 700;

      letter-spacing: 0.08em;

      text-transform: uppercase;
    }

    .hero h1 {
      max-width: 760px;

      margin:
        0
        0
        10px;

      font-size: clamp(
        34px,
        5vw,
        54px
      );

      line-height: 1.05;

      letter-spacing: -0.035em;
    }

    .hero-description {
      max-width: 820px;

      margin: 0;

      color:
        rgba(
          255,
          255,
          255,
          0.88
        );

      font-size: 17px;
    }

    .hero-metadata {
      display: flex;

      flex-wrap: wrap;

      gap: 10px;

      margin-top: 24px;
    }

    .hero-metadata span {
      padding:
        7px
        12px;

      border:
        1px solid
        rgba(
          255,
          255,
          255,
          0.22
        );

      border-radius: 999px;

      background:
        rgba(
          255,
          255,
          255,
          0.14
        );

      font-size: 13px;
    }

    /* =====================================================
       PAGE LAYOUT
    ===================================================== */

    .page-layout {
      display: grid;

      grid-template-columns:
        250px
        minmax(0, 1fr);

      gap: 26px;

      align-items: start;

      margin-top: 26px;
    }

    /* =====================================================
       TABLE OF CONTENTS
    ===================================================== */

    .table-of-contents {
      position: sticky;

      top: 20px;

      padding: 20px;

      border:
        1px solid
        var(--border);

      border-radius:
        var(--radius-large);

      background:
        var(--surface);

      box-shadow:
        0 4px 14px
        rgba(
          9,
          30,
          66,
          0.07
        );
    }

    .table-of-contents h3 {
      margin:
        0
        0
        12px;

      color:
        var(--muted);

      font-size: 13px;

      letter-spacing: 0.08em;

      text-transform: uppercase;
    }

    .table-of-contents a {
      display: block;

      margin: 4px 0;

      padding:
        9px
        10px;

      border-radius:
        var(--radius-small);

      color:
        var(--text);

      font-size: 14px;

      text-decoration: none;

      transition:
        background 0.2s ease,
        color 0.2s ease;
    }

    .table-of-contents a:hover {
      color:
        var(--pq-green-dark);

      background:
        var(--pq-green-soft);
    }

    /* =====================================================
       MAIN CONTENT
    ===================================================== */

    .content {
      display: grid;

      gap: 22px;
    }

    .introduction,
    .rule-card,
    .summary {
      border:
        1px solid
        var(--border);

      border-radius:
        var(--radius-large);

      background:
        var(--surface);

      box-shadow:
        0 4px 14px
        rgba(
          9,
          30,
          66,
          0.06
        );
    }

    .introduction {
      padding: 26px;

      border-left:
        5px solid
        var(--pq-blue);
    }

    .introduction strong {
      color:
        var(--pq-blue);
    }

    /* =====================================================
       RULE CARDS
    ===================================================== */

    .rule-card {
      overflow: hidden;
    }

    .rule-header {
      display: flex;

      align-items: flex-start;

      gap: 16px;

      padding:
        24px
        26px
        18px;

      border-bottom:
        1px solid
        var(--border);

      background:
        linear-gradient(
          180deg,
          #ffffff,
          #fbfcfd
        );
    }

    .rule-number {
      display: grid;

      flex: 0 0 auto;

      place-items: center;

      width: 42px;
      height: 42px;

      border-radius: 12px;

      color: #ffffff;

      background:
        linear-gradient(
          135deg,
          var(--pq-green-dark),
          var(--pq-green)
        );

      box-shadow:
        0 5px 12px
        rgba(
          22,
          131,
          84,
          0.23
        );

      font-size: 16px;
      font-weight: 800;
    }

    .rule-title {
      margin:
        0
        0
        4px;

      font-size: 23px;

      line-height: 1.2;

      letter-spacing: -0.01em;
    }

    .rule-subtitle {
      margin: 0;

      color:
        var(--muted);
    }

    .rule-body {
      padding:
        24px
        26px
        28px;
    }

    .rule-grid {
      display: grid;

      grid-template-columns:
        minmax(0, 1.25fr)
        minmax(270px, 0.75fr);

      gap: 20px;

      align-items: start;
    }

    .section-label {
      display: inline-block;

      margin-bottom: 9px;

      color:
        var(--muted);

      font-size: 12px;
      font-weight: 800;

      letter-spacing: 0.08em;

      text-transform: uppercase;
    }

    /* =====================================================
       CODE
    ===================================================== */

    .code-block {
      margin: 0;

      padding: 20px;

      overflow-x: auto;

      border:
        1px solid
        #243444;

      border-radius:
        var(--radius-medium);

      background:
        var(--code-background);

      box-shadow:
        inset 0 1px 0
        rgba(
          255,
          255,
          255,
          0.04
        );

      color: #dbe7f3;

      font:
        14px / 1.65
        Consolas,
        "SFMono-Regular",
        Menlo,
        Monaco,
        monospace;

      white-space: pre;
    }

    .code-block .function {
      color: #7dd3fc;
    }

    .code-block .string {
      color: #86efac;
    }

    .code-block .step {
      color: #fde68a;
    }

    .code-block .keyword {
      color: #c4b5fd;
    }

    code {
      padding:
        2px
        6px;

      border-radius: 5px;

      color: #7a1fa2;

      background: #f6eef9;

      font-family:
        Consolas,
        monospace;

      font-size: 0.92em;
    }

    /* =====================================================
       CHECKLIST
    ===================================================== */

    .checklist {
      padding: 18px;

      border:
        1px solid
        var(--border);

      border-radius:
        var(--radius-medium);

      background:
        var(--surface-soft);
    }

    .checklist h4 {
      margin:
        0
        0
        12px;

      font-size: 15px;
    }

    .checklist-item {
      display: flex;

      gap: 10px;

      margin: 10px 0;

      color: #344563;

      font-size: 14px;
    }

    .checklist-item::before {
      content: "✓";

      display: grid;

      flex:
        0
        0
        21px;

      place-items: center;

      width: 21px;
      height: 21px;

      border:
        1px solid
        #b7e3cb;

      border-radius: 50%;

      color:
        var(--pq-green-dark);

      background: #dff5e9;

      font-size: 12px;
      font-weight: 900;
    }

    /* =====================================================
       CALLOUTS
    ===================================================== */

    .callout {
      margin-top: 18px;

      padding:
        16px
        18px;

      border:
        1px solid
        #cce0ff;

      border-radius:
        var(--radius-medium);

      color: #174ea6;

      background:
        var(--pq-blue-soft);
    }

    .callout.warning {
      border-color: #f4d48b;

      color:
        var(--pq-amber);

      background:
        var(--pq-amber-soft);
    }

    .callout strong {
      display: block;

      margin-bottom: 3px;
    }

    /* =====================================================
       TABLES
    ===================================================== */

    .table-wrapper {
      overflow-x: auto;

      border:
        1px solid
        var(--border);

      border-radius:
        var(--radius-medium);
    }

    table {
      width: 100%;

      border-collapse: collapse;

      background: #ffffff;

      font-size: 14px;
    }

    th,
    td {
      padding:
        13px
        15px;

      text-align: left;

      border-bottom:
        1px solid
        var(--border);
    }

    th {
      color: #344563;

      background: #f4f5f7;

      font-weight: 700;
    }

    tr:last-child td {
      border-bottom: 0;
    }

    /* =====================================================
       DO AND DON'T
    ===================================================== */

    .do-dont-grid {
      display: grid;

      grid-template-columns:
        1fr
        1fr;

      gap: 16px;

      margin-top: 18px;
    }

    .do-card,
    .dont-card {
      padding: 17px;

      border-radius:
        var(--radius-medium);
    }

    .do-card {
      border:
        1px solid
        #b7e3cb;

      background:
        var(--pq-green-soft);
    }

    .dont-card {
      border:
        1px solid
        #f3c6c2;

      background:
        var(--pq-red-soft);
    }

    .do-card strong {
      color:
        var(--pq-green-dark);
    }

    .dont-card strong {
      color:
        var(--pq-red);
    }

    /* =====================================================
       SUMMARY
    ===================================================== */

    .summary {
      padding: 26px;
    }

    .summary h2 {
      margin:
        0
        0
        16px;
    }

    .summary-grid {
      display: grid;

      grid-template-columns:
        repeat(
          3,
          1fr
        );

      gap: 14px;
    }

    .summary-item {
      padding: 17px;

      border:
        1px solid
        var(--border);

      border-radius: 12px;

      background: #fbfcfd;
    }

    .summary-item strong {
      display: block;

      margin-bottom: 4px;

      color:
        var(--pq-green-dark);
    }

    /* =====================================================
       FOOTER
    ===================================================== */

    .footer {
      margin-top: 24px;

      padding: 18px;

      color:
        var(--muted);

      font-size: 13px;

      text-align: center;
    }

    /* =====================================================
       RESPONSIVE
    ===================================================== */

    @media (max-width: 900px) {
      .page-layout {
        grid-template-columns: 1fr;
      }

      .table-of-contents {
        position: static;
      }

      .rule-grid,
      .summary-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 620px) {
      .document {
        padding-inline: 12px;
      }

      .hero {
        padding:
          28px
          22px;
      }

      .rule-header,
      .rule-body,
      .introduction,
      .summary {
        padding-left: 20px;
        padding-right: 20px;
      }

      .do-dont-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <main class="document">

    <!-- ===================================================
         HERO
    ==================================================== -->

    <header class="hero">

      <div class="hero-label">
        Power BI Governance · Power Query / M
      </div>

      <h1>
        Power Query Development Rules
      </h1>

      <p class="hero-description">
        A practical standard for building queries that are
        structured, readable, efficient, reusable and easy to
        maintain.
      </p>

      <div class="hero-metadata">
        <span>Owner: Data Team</span>
        <span>Version: 1.0</span>
        <span>Review cycle: Quarterly</span>
      </div>

    </header>

    <!-- ===================================================
         PAGE LAYOUT
    ==================================================== -->

    <div class="page-layout">

      <!-- =================================================
           TABLE OF CONTENTS
      ================================================== -->

      <aside class="table-of-contents">

        <h3>On this page</h3>

        <a href="#rule-1">
          1. Select required columns
        </a>

        <a href="#rule-2">
          2. Standardize column names
        </a>

        <a href="#rule-3">
          3. Define data types
        </a>

        <a href="#rule-4">
          4. Preserve query folding
        </a>

        <a href="#rule-5">
          5. Name transformation steps
        </a>

        <a href="#summary">
          Final checklist
        </a>

      </aside>

      <!-- =================================================
           CONTENT
      ================================================== -->

      <section class="content">

        <!-- INTRODUCTION -->

        <div class="introduction">

          <strong>Purpose.</strong>

          These rules establish a consistent approach for
          Power Query development across Power BI reports,
          dataflows and reusable transformation pipelines.

        </div>

        <!-- =================================================
             RULE 1
        ================================================== -->

        <article
          class="rule-card"
          id="rule-1"
        >

          <div class="rule-header">

            <div class="rule-number">
              01
            </div>

            <div>

              <h2 class="rule-title">
                Select only the required columns
              </h2>

              <p class="rule-subtitle">
                Reduce the dataset as early as possible without
                negatively affecting query folding.
              </p>

            </div>

          </div>

          <div class="rule-body">

            <div class="rule-grid">

              <div>

                <span class="section-label">
                  Example
                </span>

                <pre class="code-block"><span class="step">#"Selected Required Columns"</span> =
    <span class="function">Table.SelectColumns</span>(
        Source,
        {
            <span class="string">"CUSTOMER_ID"</span>,
            <span class="string">"ORDER_DATE"</span>,
            <span class="string">"STATUS"</span>,
            <span class="string">"AMOUNT"</span>
        }
    )</pre>

              </div>

              <div class="checklist">

                <h4>
                  Required-column checklist
                </h4>

                <div class="checklist-item">
                  Keep only columns used in the model or later
                  transformation steps.
                </div>

                <div class="checklist-item">
                  Remove unnecessary technical and helper
                  columns.
                </div>

                <div class="checklist-item">
                  Reduce rows before expensive transformations.
                </div>

                <div class="checklist-item">
                  Confirm that removed columns are not needed
                  later.
                </div>

              </div>

            </div>

            <div class="callout">

              <strong>
                Why this matters
              </strong>

              Smaller datasets improve refresh time, memory
              usage and transformation performance.

            </div>

          </div>

        </article>

        <!-- =================================================
             RULE 2
        ================================================== -->

        <article
          class="rule-card"
          id="rule-2"
        >

          <div class="rule-header">

            <div class="rule-number">
              02
            </div>

            <div>

              <h2 class="rule-title">
                Standardize column names
              </h2>

              <p class="rule-subtitle">
                Use one naming convention throughout the entire
                semantic model.
              </p>

            </div>

          </div>

          <div class="rule-body">

            <span class="section-label">
              Recommended convention
            </span>

            <div class="table-wrapper">

              <table>

                <thead>

                  <tr>
                    <th>Element</th>
                    <th>Rule</th>
                    <th>Example</th>
                  </tr>

                </thead>

                <tbody>

                  <tr>
                    <td>Business columns</td>
                    <td>Use clear English names</td>
                    <td>
                      <code>Customer ID</code>
                    </td>
                  </tr>

                  <tr>
                    <td>Date columns</td>
                    <td>End with “Date”</td>
                    <td>
                      <code>Order Date</code>
                    </td>
                  </tr>

                  <tr>
                    <td>Boolean columns</td>
                    <td>Start with “Is” or “Has”</td>
                    <td>
                      <code>Is Active</code>
                    </td>
                  </tr>

                  <tr>
                    <td>Key columns</td>
                    <td>Use a consistent key suffix</td>
                    <td>
                      <code>Customer Key</code>
                    </td>
                  </tr>

                </tbody>

              </table>

            </div>

            <div class="do-dont-grid">

              <div class="do-card">

                <strong>Do</strong>

                <br>

                Use descriptive names such as
                <code>Order Date</code>
                and
                <code>Net Amount</code>.

              </div>

              <div class="dont-card">

                <strong>Avoid</strong>

                <br>

                Ambiguous abbreviations such as
                <code>OD_DT</code>
                or
                <code>AMT_N</code>.

              </div>

            </div>

          </div>

        </article>

        <!-- =================================================
             RULE 3
        ================================================== -->

        <article
          class="rule-card"
          id="rule-3"
        >

          <div class="rule-header">

            <div class="rule-number">
              03
            </div>

            <div>

              <h2 class="rule-title">
                Define data types explicitly
              </h2>

              <p class="rule-subtitle">
                Apply the correct type before joins,
                calculations and model loading.
              </p>

            </div>

          </div>

          <div class="rule-body">

            <div class="rule-grid">

              <div>

                <span class="section-label">
                  Example
                </span>

                <pre class="code-block"><span class="step">#"Changed Data Types"</span> =
    <span class="function">Table.TransformColumnTypes</span>(
        <span class="step">#"Selected Required Columns"</span>,
        {
            {<span class="string">"CUSTOMER_ID"</span>, <span class="keyword">Int64.Type</span>},
            {<span class="string">"ORDER_DATE"</span>, <span class="keyword">type date</span>},
            {<span class="string">"AMOUNT"</span>, <span class="keyword">Currency.Type</span>}
        }
    )</pre>

              </div>

              <div class="checklist">

                <h4>
                  Type validation
                </h4>

                <div class="checklist-item">
                  Keys use compatible data types on both sides
                  of joins.
                </div>

                <div class="checklist-item">
                  Dates are not stored as text.
                </div>

                <div class="checklist-item">
                  Decimal and currency fields use the correct
                  precision.
                </div>

                <div class="checklist-item">
                  Errors are reviewed before loading.
                </div>

              </div>

            </div>

          </div>

        </article>

        <!-- =================================================
             RULE 4
        ================================================== -->

        <article
          class="rule-card"
          id="rule-4"
        >

          <div class="rule-header">

            <div class="rule-number">
              04
            </div>

            <div>

              <h2 class="rule-title">
                Preserve query folding
              </h2>

              <p class="rule-subtitle">
                Push transformations to the source whenever
                the connector supports it.
              </p>

            </div>

          </div>

          <div class="rule-body">

            <div class="callout warning">

              <strong>
                Important
              </strong>

              Apply filters, column selection and simple
              transformations before steps that may break
              query folding.

            </div>

            <div class="do-dont-grid">

              <div class="do-card">

                <strong>Prefer</strong>

                <br>

                Filtering rows, selecting columns, simple
                renames and source-side aggregations.

              </div>

              <div class="dont-card">

                <strong>Review carefully</strong>

                <br>

                Custom functions, row-by-row logic,
                unsupported transformations and local
                buffering.

              </div>

            </div>

          </div>

        </article>

        <!-- =================================================
             RULE 5
        ================================================== -->

        <article
          class="rule-card"
          id="rule-5"
        >

          <div class="rule-header">

            <div class="rule-number">
              05
            </div>

            <div>

              <h2 class="rule-title">
                Use meaningful step names
              </h2>

              <p class="rule-subtitle">
                Each applied step should explain what changed
                and why.
              </p>

            </div>

          </div>

          <div class="rule-body">

            <div class="table-wrapper">

              <table>

                <thead>

                  <tr>
                    <th>Avoid</th>
                    <th>Use instead</th>
                  </tr>

                </thead>

                <tbody>

                  <tr>
                    <td>
                      <code>Changed Type1</code>
                    </td>

                    <td>
                      <code>
                        Changed Customer Data Types
                      </code>
                    </td>
                  </tr>

                  <tr>
                    <td>
                      <code>Filtered Rows2</code>
                    </td>

                    <td>
                      <code>
                        Filtered Active Orders
                      </code>
                    </td>
                  </tr>

                  <tr>
                    <td>
                      <code>Merged Queries1</code>
                    </td>

                    <td>
                      <code>
                        Merged Customer Dimension
                      </code>
                    </td>
                  </tr>

                </tbody>

              </table>

            </div>

            <div class="callout">

              <strong>
                Recommended pattern
              </strong>

              Use past-tense action names:

              <code>Selected</code>,
              <code>Filtered</code>,
              <code>Renamed</code>,
              <code>Merged</code>,
              <code>Expanded</code>
              and
              <code>Grouped</code>.

            </div>

          </div>

        </article>

        <!-- =================================================
             SUMMARY
        ================================================== -->

        <section
          class="summary"
          id="summary"
        >

          <h2>
            Final validation checklist
          </h2>

          <div class="summary-grid">

            <div class="summary-item">

              <strong>
                Performance
              </strong>

              Required rows and columns only.

            </div>

